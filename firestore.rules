rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isParticipant(conversationId) {
      return isSignedIn() && 
        (exists(/databases/$(database)/documents/conversations/$(conversationId)) && 
         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
    }

    function conversationDoc(conversationId) {
      return /databases/$(database)/documents/conversations/$(conversationId);
    }

    function isConversationParticipant(conversationId) {
      return isSignedIn() &&
        exists(conversationDoc(conversationId)) &&
        request.auth.uid in get(conversationDoc(conversationId)).data.participants;
    }

    function jobDoc(jobId) {
      return /databases/$(database)/documents/jobs/$(jobId);
    }

    function applicationDoc(applicationId) {
      return /databases/$(database)/documents/job_applications/$(applicationId);
    }

    function ratingDoc(ratingId) {
      return /databases/$(database)/documents/user_ratings/$(ratingId);
    }

    function isJobOwner(jobId) {
      return isSignedIn() &&
        exists(jobDoc(jobId)) &&
        get(jobDoc(jobId)).data.providerId == request.auth.uid;
    }

    function isNotificationOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      // Allow any signed-in user to see other users' basic profiles for chat
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.providerId == request.auth.uid
        && request.resource.data.status == 'available';

      allow update, delete: if isJobOwner(jobId);
    }

    match /job_applications/{applicationId} {
      allow read: if isSignedIn() && (
        resource.data.applicantId == request.auth.uid ||
        resource.data.providerId == request.auth.uid ||
        (resource.data.jobId is string && isJobOwner(resource.data.jobId))
      );

      allow create: if isSignedIn()
        && request.resource.data.applicantId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.jobId is string
        && exists(jobDoc(request.resource.data.jobId))
        && get(jobDoc(request.resource.data.jobId)).data.providerId == request.resource.data.providerId
        && request.resource.data.providerId != request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.jobId is string
        && isJobOwner(resource.data.jobId)
        && request.resource.data.jobId == resource.data.jobId
        && request.resource.data.applicantId == resource.data.applicantId
        && request.resource.data.providerId == resource.data.providerId;

      allow delete: if isSignedIn()
        && resource.data.jobId is string
        && isJobOwner(resource.data.jobId);
    }

    match /user_ratings/{ratingId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'applicationId',
          'jobId',
          'jobTitle',
          'ratedUserId',
          'raterId',
          'raterName',
          'rating',
          'feedback',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.applicationId == ratingId
        && request.resource.data.raterId == request.auth.uid
        && request.resource.data.ratedUserId is string
        && request.resource.data.jobId is string
        && request.resource.data.jobTitle is string
        && request.resource.data.jobTitle == get(jobDoc(request.resource.data.jobId)).data.title
        && request.resource.data.raterName is string
        && request.resource.data.feedback is string
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && exists(applicationDoc(request.resource.data.applicationId))
        && exists(jobDoc(request.resource.data.jobId))
        && get(applicationDoc(request.resource.data.applicationId)).data.providerId == request.auth.uid
        && get(applicationDoc(request.resource.data.applicationId)).data.jobId == request.resource.data.jobId
        && get(applicationDoc(request.resource.data.applicationId)).data.applicantId == request.resource.data.ratedUserId
        && get(jobDoc(request.resource.data.jobId)).data.providerId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.raterId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'applicationId',
          'jobId',
          'jobTitle',
          'ratedUserId',
          'raterId',
          'raterName',
          'rating',
          'feedback',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.applicationId == resource.data.applicationId
        && request.resource.data.jobId == resource.data.jobId
        && request.resource.data.jobTitle == resource.data.jobTitle
        && request.resource.data.ratedUserId == resource.data.ratedUserId
        && request.resource.data.raterId == resource.data.raterId
        && request.resource.data.raterName == resource.data.raterName
        && request.resource.data.feedback is string
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && exists(applicationDoc(resource.data.applicationId))
        && exists(jobDoc(resource.data.jobId))
        && get(applicationDoc(resource.data.applicationId)).data.providerId == request.auth.uid
        && get(applicationDoc(resource.data.applicationId)).data.applicantId == resource.data.ratedUserId
        && get(jobDoc(resource.data.jobId)).data.providerId == request.auth.uid;

      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, delete: if isNotificationOwner();

      allow update: if isNotificationOwner()
        && request.resource.data.userId == resource.data.userId;

      allow create: if isSignedIn()
        && request.resource.data.type == 'application'
        && (
          (
            request.resource.data.data is map &&
            request.resource.data.data.jobId is string &&
            request.resource.data.data.applicantId == request.auth.uid &&
            exists(jobDoc(request.resource.data.data.jobId)) &&
            get(jobDoc(request.resource.data.data.jobId)).data.providerId == request.resource.data.userId
          ) ||
          (
            request.resource.data.data is map &&
            request.resource.data.data.applicationId is string &&
            exists(applicationDoc(request.resource.data.data.applicationId)) &&
            get(applicationDoc(request.resource.data.data.applicationId)).data.providerId == request.auth.uid &&
            get(applicationDoc(request.resource.data.data.applicationId)).data.applicantId == request.resource.data.userId
          )
        );
    }

    match /conversations/{conversationId} {
      // Use the document's own participants array so list queries can be authorized.
      allow get, list: if isSignedIn() &&
        request.auth.uid in resource.data.participants;

      allow create: if isSignedIn() &&
          request.resource.data.participants is list &&
          request.resource.data.participants.size() == 2 &&
          request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);

        allow create: if (isParticipant(conversationId) || 
            (isSignedIn() && request.auth.uid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.participants)) &&
            request.resource.data.senderId == request.auth.uid;

        allow update: if isConversationParticipant(conversationId);
        allow delete: if false;
      }
    }
  }
}
